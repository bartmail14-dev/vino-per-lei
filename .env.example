# ============================================================
# BELANGRIJK: Als tokens ooit in git history zijn beland,
# roteer ze ONMIDDELLIJK in het betreffende dashboard.
# Zie HANDOFF-VPL.md voor instructies per token.
# ============================================================

# Shopify Storefront API (public — safe for client-side)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token

# Shopify Admin API (PRIVATE — server-side only, never prefix with NEXT_PUBLIC_)
# ROTEER dit token als het ooit in git history is beland!
# Ga naar Shopify Admin → Settings → Apps → API credentials → Regenerate
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_token

# Mailgun (PRIVATE — server-side only)
# Maak een account op https://app.mailgun.com en kopieer je API key
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.vinoperlei.nl
MAILGUN_REGION=eu
CONTACT_EMAIL=info@vinoperlei.nl

# remove.bg API (PRIVATE — server-side only)
# Gratis account: 50 afbeeldingen/maand — https://www.remove.bg/api
REMOVE_BG_API_KEY=your-remove-bg-api-key

# Rate limiting (optioneel — cookie signing secret)
# Genereer met: openssl rand -base64 32
RATE_LIMIT_SECRET=

# Email preview route access (PRIVATE — alleen voor development)
# Genereer met: openssl rand -hex 16
EMAIL_PREVIEW_SECRET=

# E-mail livegang testadressen (alleen lokaal gebruiken)
EMAIL_TEST_RECIPIENTS=gmail-test@example.com,outlook-test@example.com

# Google Analytics 4 (public — client-side)
# Maak een GA4 property op https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console (public — meta tag verification)
# Kopieer de verificatiecode uit GSC → Settings → Ownership verification → HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Shopify Webhook Secret (PRIVATE — server-side only)
# Gebruikt voor ISR revalidation endpoint /api/revalidate
# Genereer met: openssl rand -hex 32
SHOPIFY_WEBHOOK_SECRET=
